        {"id": "rpt_r1_20260704_002_s4", "sentence": "Our staff weighs every load before it is processed.", "difficulty": "medium", "word_count": 9, "structure": "declarative with subordinate clause", "phonetic_focus": "final consonant cluster in 'processed'", "timing_seconds": 10},
        {"id": "rpt_r1_20260704_002_s5", "sentence": "You can drop off old electronics at the back counter.", "difficulty": "medium", "word_count": 10, "structure": "declarative with prepositional phrase", "phonetic_focus": "stress in compound 'back counter'", "timing_seconds": 10},
        {"id": "rpt_r1_20260704_002_s6", "sentence": "Compost from the dining halls is turned into garden soil.", "difficulty": "medium", "word_count": 10, "structure": "passive with prepositional phrase", "phonetic_focus": "linking 'turned_into'", "timing_seconds": 10},
        {"id": "rpt_r1_20260704_002_s7", "sentence": "If you are unsure where something belongs, check the labeled chart posted by the entrance.", "difficulty": "hard", "word_count": 15, "structure": "fronted conditional with wayfinding pointer", "phonetic_focus": "reduced function words 'by the'", "timing_seconds": 12}
      ]
