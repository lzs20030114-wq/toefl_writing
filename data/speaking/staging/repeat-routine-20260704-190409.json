      "speaker_role": "sustainability coordinator",
      "sentences": [
        {"id": "rpt_r1_20260704_002_s1", "sentence": "The sorting bins are along this wall.", "difficulty": "easy", "word_count": 7, "structure": "bare declarative locating", "phonetic_focus": "consonant cluster 'rt' in 'sorting'", "timing_seconds": 8},
        {"id": "rpt_r1_20260704_002_s2", "sentence": "Glass and metal go in separate bins.", "difficulty": "easy", "word_count": 7, "structure": "simple declarative", "phonetic_focus": "reduced syllables in 'separate'", "timing_seconds": 8},
