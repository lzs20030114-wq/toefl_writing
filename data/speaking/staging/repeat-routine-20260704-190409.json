        {"id": "rpt_r1_20260704_003_s4", "sentence": "The reclining seats let you view the entire ceiling.", "difficulty": "medium", "word_count": 9, "structure": "declarative with object clause", "phonetic_focus": "linking 'let_you'", "timing_seconds": 10},
