      "speaker_role": "art class instructor",
      "sentences": [
        {"id": "rpt_r1_20260704_001_s1", "sentence": "First, tape your paper to the board.", "difficulty": "easy", "word_count": 7, "structure": "bare imperative", "phonetic_focus": "clear word-final consonants", "timing_seconds": 8},
        {"id": "rpt_r1_20260704_001_s2", "sentence": "Next, fill a jar with clean water.", "difficulty": "easy", "word_count": 7, "structure": "bare imperative", "phonetic_focus": "consonant cluster 'cl-'", "timing_seconds": 8},
