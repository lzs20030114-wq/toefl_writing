        {"id": "rpt_r1_20260704_001_s4", "sentence": "Wet the paper evenly with a wide brush.", "difficulty": "medium", "word_count": 8, "structure": "imperative with adverbial", "phonetic_focus": "reduced syllables in 'evenly'", "timing_seconds": 10},
        {"id": "rpt_r1_20260704_001_s5", "sentence": "Load your brush with a light, watery wash of color.", "difficulty": "medium", "word_count": 10, "structure": "imperative with prepositional phrase", "phonetic_focus": "linking 'wash_of'", "timing_seconds": 10},
        {"id": "rpt_r1_20260704_001_s6", "sentence": "Let each layer dry before adding a darker tone.", "difficulty": "medium", "word_count": 9, "structure": "imperative with participial extension", "phonetic_focus": "stress in compound 'darker tone'", "timing_seconds": 10},
        {"id": "rpt_r1_20260704_001_s7", "sentence": "When you are finished painting, rinse your brushes well and lay them flat to dry.", "difficulty": "hard", "word_count": 15, "structure": "fronted temporal clause with compound", "phonetic_focus": "conditional intonation across the comma boundary", "timing_seconds": 12}
