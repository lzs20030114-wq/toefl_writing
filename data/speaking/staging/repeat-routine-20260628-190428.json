        {"id": "rpt_20260628190428_002_s6", "sentence": "Press a fresh patch firmly over the small puncture.", "difficulty": "medium", "word_count": 9, "structure": "imperative with adverbial", "phonetic_focus": "stress placement in compound nouns", "timing_seconds": 10},
        {"id": "rpt_20260628190428_002_s7", "sentence": "Once the patch holds, slide the tube back inside and pump the tire up firmly.", "difficulty": "hard", "word_count": 15, "structure": "fronted temporal clause with compound predicate", "phonetic_focus": "linked speech across clause boundaries", "timing_seconds": 12}
