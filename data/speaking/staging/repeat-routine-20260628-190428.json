      "speaker_role": "workshop instructor",
      "sentences": [
        {"id": "rpt_20260628190428_002_s1", "sentence": "First, loosen the wheel bolts.", "difficulty": "easy", "word_count": 5, "structure": "bare imperative", "phonetic_focus": "clear word-final consonants", "timing_seconds": 8},
