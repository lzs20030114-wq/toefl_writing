DEEPSEEK_API_KEY=your_key_here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ADMIN_DASHBOARD_TOKEN=your_admin_token

# Feature flags
NEXT_PUBLIC_IAP_ENABLED=false
IAP_ENABLED=false

# IAP provider config (mock | afdian)
IAP_PROVIDER=mock
IAP_WEBHOOK_SECRET=replace_with_long_random_secret
IAP_ALLOW_MOCK_WEBHOOK_SIMULATION=false
# Optional: override default products with a JSON array
# IAP_PRODUCTS_JSON=[{"id":"pro_monthly","title":"TOEFL Pro Monthly","description":"Monthly premium access","priceCents":990,"currency":"USD","interval":"month","active":true}]

# Afdian (爱发电) provider config — set IAP_PROVIDER=afdian to use
AFDIAN_API_TOKEN=your_afdian_api_token
AFDIAN_USER_ID=your_afdian_user_id
AFDIAN_SPONSOR_URL=https://afdian.com/a/treepractice
