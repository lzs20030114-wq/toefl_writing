# ── AI 服务 ─────────────────────────────────────────────
DEEPSEEK_API_KEY=your_key_here
# 可选：代理地址（用于国内服务器访问 DeepSeek API）
# DEEPSEEK_PROXY_URL=http://your-proxy:port

# ── OpenAI（仅用于 Speaking 任务的 STT，调用 Whisper-1）─
# Vercel 美区 function 直连 OpenAI，无需代理；本地开发若需调试 STT，可在
# .env.local 里设置 HTTPS_PROXY 让本机 dev server 也能调通 OpenAI。
OPENAI_API_KEY=your_openai_key_here
# HTTPS_PROXY=http://127.0.0.1:10808

# ── 通义千问 Qwen3-VL（视觉识别：用户上传题库图片 → 抽取题目）────
# 阿里云百炼(Model Studio)控制台 → API-KEY 管理 创建。OpenAI 兼容接口。
# 大陆(北京)endpoint 国内可直连、数据境内、无需代理 —— 这是默认值。
# 若用国际(新加坡)区，把 DASHSCOPE_BASE_URL 改成 dashscope-intl 那个。
DASHSCOPE_API_KEY=your_dashscope_key_here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   # 大陆(默认)
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1  # 国际/免费额度区
# QWEN_VL_MODEL=qwen3-vl-plus   # 默认主力；批量可换 qwen3-vl-flash

# ── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── 管理后台 ────────────────────────────────────────────
ADMIN_DASHBOARD_TOKEN=your_admin_token

# ── 网站域名（用于 SEO、sitemap 等） ───────────────────
NEXT_PUBLIC_SITE_URL=https://treepractice.com

# ── 邮件（用于邀请奖励到账通知等事务性邮件） ───────────
# QQ Mail SMTP 授权码：在 QQ 邮箱 → 设置 → 账户 → 开启 SMTP 后获得（16 位字母）
# 注意：MAIL_PASS 不是邮箱登录密码，是单独的 16 位授权码
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your_qq_email@qq.com
MAIL_PASS=your_16_char_smtp_authorization_code
MAIL_FROM_NAME=TreePractice

# ── GitHub Actions 题目生成（可选） ─────────────────────
# GH_OWNER=your_github_username
# GH_REPO=your_repo_name
# GH_PAT=your_github_personal_access_token

# ── 功能开关 ────────────────────────────────────────────
NEXT_PUBLIC_IAP_ENABLED=false
IAP_ENABLED=false

# ── 支付（IAP）配置 ────────────────────────────────────
# 提供商：mock（测试）| afdian（爱发电）| xorpay（虎皮椒）
IAP_PROVIDER=mock
IAP_WEBHOOK_SECRET=replace_with_long_random_secret
IAP_ALLOW_MOCK_WEBHOOK_SIMULATION=false

# 可选：自定义产品列表（JSON 数组）
# IAP_PRODUCTS_JSON=[{"id":"pro_monthly","title":"Pro Monthly","priceCents":990,"currency":"USD","interval":"month","active":true}]

# ── 爱发电配置（IAP_PROVIDER=afdian 时必填） ───────────
AFDIAN_API_TOKEN=your_afdian_api_token
AFDIAN_USER_ID=your_afdian_user_id
AFDIAN_SPONSOR_URL=https://ifdian.net/a/treepractice

# ── 虎皮椒配置（IAP_PROVIDER=xorpay 时必填） ────────────
XORPAY_AID=your_xorpay_merchant_id
XORPAY_APP_SECRET=your_xorpay_app_secret
XORPAY_NOTIFY_URL=https://yourdomain.com/api/iap/webhook
