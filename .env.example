# ── AI 服务 ─────────────────────────────────────────────
DEEPSEEK_API_KEY=your_key_here
# 可选：代理地址（用于国内服务器访问 DeepSeek API）
# DEEPSEEK_PROXY_URL=http://your-proxy:port

# ── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── 管理后台 ────────────────────────────────────────────
ADMIN_DASHBOARD_TOKEN=your_admin_token

# ── 网站域名（用于 SEO、sitemap 等） ───────────────────
NEXT_PUBLIC_SITE_URL=https://treepractice.com

# ── GitHub Actions 题目生成（可选） ─────────────────────
# GH_OWNER=your_github_username
# GH_REPO=your_repo_name
# GH_PAT=your_github_personal_access_token

# ── 功能开关 ────────────────────────────────────────────
NEXT_PUBLIC_IAP_ENABLED=false
IAP_ENABLED=false

# ── 支付（IAP）配置 ────────────────────────────────────
# 提供商：mock（测试）| afdian（爱发电）
IAP_PROVIDER=mock
IAP_WEBHOOK_SECRET=replace_with_long_random_secret
IAP_ALLOW_MOCK_WEBHOOK_SIMULATION=false

# 可选：自定义产品列表（JSON 数组）
# IAP_PRODUCTS_JSON=[{"id":"pro_monthly","title":"Pro Monthly","priceCents":990,"currency":"USD","interval":"month","active":true}]

# ── 爱发电配置（IAP_PROVIDER=afdian 时必填） ───────────
AFDIAN_API_TOKEN=your_afdian_api_token
AFDIAN_USER_ID=your_afdian_user_id
AFDIAN_SPONSOR_URL=https://afdian.com/a/treepractice
